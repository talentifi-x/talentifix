# Brevo SMTP credentials (get from https://app.brevo.com -> SMTP & API)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-smtp-user@smtp-brevo.com
BREVO_SMTP_PASS=your-brevo-smtp-password

# Contact form email addresses
CONTACT_FROM_EMAIL=contact@yourdomain.com
CONTACT_FROM_NAME=YourCompanyName
CONTACT_TO_EMAIL=contact@yourdomain.com

# Sanity CMS (get from https://sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-sanity-api-token

# Optional: Sanity webhook secret for ISR revalidation
SANITY_WEBHOOK_SECRET=your-webhook-secret

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
